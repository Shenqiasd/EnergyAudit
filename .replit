modules = ["nodejs-20", "web"]

  [agent]
expertMode = true

  [nix]
  channel = "stable-25_05"

  [userenv]

  [userenv.shared]
  NODE_ENV = "development"
  API_PORT = "3001"
  NEXT_PUBLIC_API_URL = "/api/v1"
  INTERNAL_API_URL = "http://localhost:3001"

  [workflows]
  runButton = "Project"

  [[workflows.workflow]]
  name = "Project"
  mode = "parallel"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "API"

  [[workflows.workflow.tasks]]
  task = "workflow.run"
  args = "Start application"

  [[workflows.workflow]]
  name = "API"
  author = "agent"

  [workflows.workflow.metadata]
  outputType = "console"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "cd apps/api && pnpm run dev"
  waitForPort = 3001

  [[workflows.workflow]]
  name = "Start application"
  author = "agent"

  [workflows.workflow.metadata]
  outputType = "webview"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "cd apps/web && pnpm run dev"
  waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

  [deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "(cd apps/api && API_PORT=4000 NODE_ENV=production node dist/main &) && cd apps/web && NODE_ENV=production ./node_modules/.bin/next start --port 3001 -H 0.0.0.0"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @energy-audit/config-engine build && pnpm --filter @energy-audit/reporting build && NODE_ENV=production pnpm --filter @energy-audit/api run build && NODE_ENV=production INTERNAL_API_URL=http://localhost:4000 pnpm --filter @energy-audit/web run build"]
  