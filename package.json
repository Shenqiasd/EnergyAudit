{
  "name": "energy-audit-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "vitest run",
    "type-check": "turbo run type-check",
    "seed:sample": "pnpm --filter @energy-audit/api exec tsx ../../scripts/seed-sample-data.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "bcrypt", "esbuild", "sharp"],
    "patchedDependencies": {
      "next@16.2.1": "patches/next@16.2.1.patch"
    }
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
