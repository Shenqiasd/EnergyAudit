{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/manager/layout,_N_T_/manager/sync/layout,_N_T_/manager/sync/page,_N_T_/manager/sync"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/manager/sync/__PAGE__",
    "/manager/sync",
    "/manager",
    "/_index",
    "/_head"
  ]
}