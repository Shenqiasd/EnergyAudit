{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/enterprise/layout,_N_T_/enterprise/dashboard/layout,_N_T_/enterprise/dashboard/page,_N_T_/enterprise/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/enterprise/dashboard/__PAGE__",
    "/enterprise/dashboard",
    "/enterprise",
    "/_index",
    "/_head"
  ]
}