{
  "name": "@energy-audit/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @energy-audit/integrations build && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'no linter configured'",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@energy-audit/config-engine": "workspace:*",
    "@energy-audit/integrations": "workspace:*",
    "@energy-audit/reporting": "workspace:^",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.17",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.8.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0"
  }
}
