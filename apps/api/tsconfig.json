{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "paths": {
      "@energy-audit/config-engine": ["../../packages/config-engine/dist"],
      "@energy-audit/reporting": ["../../packages/reporting/dist"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
